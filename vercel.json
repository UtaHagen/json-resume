{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "resume.jsx",
      "use": "@vercel/static"
    },
    {
      "src": "resume-pdf.html",
      "use": "@vercel/static"
    },
    {
      "src": "resume.pdf",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/resume",
      "dest": "/api/resume.js"
    },
    {
      "src": "/resume",
      "dest": "/api/resume.js"
    },
    {
      "src": "/resume.jsx",
      "dest": "/resume.jsx"
    },
    {
      "src": "/resume-pdf",
      "dest": "/resume-pdf.html"
    },
    {
      "src": "/resume.pdf",
      "dest": "/resume.pdf"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
